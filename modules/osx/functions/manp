#
# Opens man pages in Preview.app.
#
# Authors:
#   Sorin Ionescu <sorin.ionescu@gmail.com>
#

function manp {
  local page
  local path

  if (( $# == 0 )); then
    return 1
  fi

  for page in "$@"; do
    path="$(/usr/bin/man -w -- "$page" 2>/dev/null)"

    if [[ -z "$path" || ! -f "$path" ]]; then
      print "No manual entry for $page" >&2
      continue
    fi

    mandoc -T pdf -- "$path" | open -fa Preview
  done
}

manp "$@"
