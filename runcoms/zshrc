alias listensocks="lsof -i -P | grep -i listen"
killport () {
  if [ -z $1 ]; then
    echo USAGE: killport PORT_NUMBER
    exit 1
  fi
  pid=$(lsof -i -P | grep -i listen | grep $1 | awk '{print $2}')
  kill -9 $pid
}

