# jq from str
function jqs {
	args=($@)
	str=${args[-1]}
	args[-1]=()
	jq $args <<< "$str"
}

# jq on a string with wrong quotes
function jqq {
  args=($@)
  args[-1]=$(sed "s/'/\"/g" <<< "${args[-1]}")
  jqs $args
}

